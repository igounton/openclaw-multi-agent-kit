// openclaw-config.jsonc — Template configuration snippet
// Copy relevant sections into your openclaw.json
// Replace all YOUR_* placeholders with actual values

{
  // Agent defaults — applied to all agents unless overridden.
  // No model is set here so agents inherit whatever provider/model
  // your OpenClaw runtime is configured with. Override per-agent in
  // `agents.list[].model` only if a role truly needs a specific model.
  "agents": {
    "defaults": {
      "workspace": "/home/YOUR_USER/.openclaw/workspace",
      "maxConcurrent": 4
    }
  },

  // Skills system (v2026.3.24+) — one-click install, ClawHub marketplace
  "skills": {
    "enabled": true
  },

  // Telegram channel config
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "streaming": "off",
      // Thread bindings — auto-spawn ACP sessions when a new topic conversation starts.
      // Lives under channels.telegram (and optionally per-account); NOT at the top-level `session`.
      "threadBindings": {
        "spawnSessions": true,
        "idleHours": 48
      }
    }
  },

  // ACP / ACPX — coding agent backend via Agent Client Protocol
  "acp": {
    "enabled": true,
    "backend": "acpx",
    "defaultAgent": "claude",
    "allowedAgents": ["claude", "codex", "opencode", "gemini", "pi"]
  },

  // Messages config
  "messages": {
    "ackReactionScope": "group-mentions"
  },

  // Session config
  "session": {
    "dmScope": "per-channel-peer"
  },

  // Hooks for boot files, memory, etc.
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": { "enabled": true },
        "bootstrap-extra-files": { "enabled": true },
        "session-memory": { "enabled": true }
      }
    }
  }
}
